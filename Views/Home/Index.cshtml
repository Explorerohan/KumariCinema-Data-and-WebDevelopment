@{
    ViewData["Title"] = "Home";
}

<div class="text-center mb-4">
    <h1 class="display-4 mb-2">Cinema Ticketing Console</h1>
    <p class="lead mb-0">Manage customers, schedules, tickets and insights in a single, elegant dashboard.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Data Management</h5>
            </div>
            <div class="card-body home-quick-links">
                <div class="home-link-grid">
                    <a asp-controller="Customer" asp-action="Index" class="home-link-tile">
                        <span>User Details (Customer)</span>
                        <span class="home-link-icon">›</span>
                    </a>
                    <a asp-controller="Hall" asp-action="Index" class="home-link-tile">
                        <span>Theatercityhall Details</span>
                        <span class="home-link-icon">›</span>
                    </a>
                    <a asp-controller="Movie" asp-action="Index" class="home-link-tile">
                        <span>Movie Details</span>
                        <span class="home-link-icon">›</span>
                    </a>
                    <a asp-controller="Showing" asp-action="Index" class="home-link-tile">
                        <span>Showtimes</span>
                        <span class="home-link-icon">›</span>
                    </a>
                    <a asp-controller="Ticket" asp-action="Index" class="home-link-tile">
                        <span>Ticket Details</span>
                        <span class="home-link-icon">›</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Reports</h5>
            </div>
            <div class="card-body home-quick-links">
                <div class="home-link-grid">
                    <a asp-controller="UserTicket" asp-action="Index" class="home-link-tile">
                        <span>User Tickets (Last 6 months)</span>
                        <span class="home-link-icon">›</span>
                    </a>
                    <a asp-controller="TheaterMovie" asp-action="Index" class="home-link-tile">
                        <span>Theater/Hall Movies</span>
                        <span class="home-link-icon">›</span>
                    </a>
                    <a asp-controller="Occupancy" asp-action="Index" class="home-link-tile">
                        <span>Top Occupancy by Movie</span>
                        <span class="home-link-icon">›</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Quick Info</h5>
            </div>
            <div class="card-body">
                <p class="small mb-2">This academic project demonstrates a cinema ticketing system built on ASP.NET Core MVC with an Oracle database backend.</p>
                <p class="small mb-0 text-muted">It covers end‑to‑end management of customers, theaters, halls, movies, showtimes and tickets, plus reporting on user tickets, movie scheduling and occupancy.</p>
            </div>
        </div>
    </div>
</div>
