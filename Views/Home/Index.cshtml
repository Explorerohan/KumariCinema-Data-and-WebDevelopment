@{
    ViewData["Title"] = "Home";
}

<div class="text-center mb-4">
    <h1 class="display-4">Cinema Ticketing System</h1>
    <p class="lead">Oracle-based cinema management - Academic Demo</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Data Management</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="mb-2"><a asp-controller="Customer" asp-action="Index" class="text-decoration-none">User Details (Customer)</a></li>
                    <li class="mb-2"><a asp-controller="Hall" asp-action="Index" class="text-decoration-none">Theater/Hall Details</a></li>
                    <li class="mb-2"><a asp-controller="Movie" asp-action="Index" class="text-decoration-none">Movie Details</a></li>
                    <li class="mb-2"><a asp-controller="Showing" asp-action="Index" class="text-decoration-none">Showtimes</a></li>
                    <li><a asp-controller="Ticket" asp-action="Index" class="text-decoration-none">Ticket Details</a></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Reports</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="mb-2"><a asp-controller="UserTicket" asp-action="Index" class="text-decoration-none">User Tickets (Last 6 months)</a></li>
                    <li class="mb-2"><a asp-controller="TheaterMovie" asp-action="Index" class="text-decoration-none">Theater/Hall Movies</a></li>
                    <li><a asp-controller="Occupancy" asp-action="Index" class="text-decoration-none">Top Occupancy by Movie</a></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Quick Info</h5>
            </div>
            <div class="card-body">
                <p class="small mb-0">Connect to Oracle database and manage cinema data. All pages support full CRUD where applicable. Reports show tickets, movies by theater, and occupancy.</p>
            </div>
        </div>
    </div>
</div>
