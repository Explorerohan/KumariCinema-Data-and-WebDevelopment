@model Ticket
@{
    ViewData["Title"] = "Delete Ticket";
}
<h2>Delete Ticket</h2>
<p class="text-danger">Are you sure you want to delete this ticket?</p>
<dl class="row">
    <dt class="col-sm-2">Ticket ID</dt>
    <dd class="col-sm-10">@Model.TicketId</dd>
    <dt class="col-sm-2">Ticket Number</dt>
    <dd class="col-sm-10">@Model.TicketNumber</dd>
    <dt class="col-sm-2">Movie</dt>
    <dd class="col-sm-10">@(Model.MovieTitle ?? "-")</dd>
    <dt class="col-sm-2">Theater / Hall</dt>
    <dd class="col-sm-10">@(Model.TheaterName ?? "-") / @(Model.HallNumber ?? "-")</dd>
    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.TicketPrice.ToString("N2")</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="TicketId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
