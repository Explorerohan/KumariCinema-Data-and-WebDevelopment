@model Showing
@{
    ViewData["Title"] = "Delete Showing";
}
<h2>Delete Showing</h2>
<p class="text-danger">Are you sure you want to delete this showing?</p>
<dl class="row">
    <dt class="col-sm-2">Showing ID</dt>
    <dd class="col-sm-10">@Model.ShowingId</dd>
    <dt class="col-sm-2">Movie</dt>
    <dd class="col-sm-10">@(Model.MovieTitle ?? "-")</dd>
    <dt class="col-sm-2">Theater / Hall</dt>
    <dd class="col-sm-10">@(Model.TheaterName ?? "-") / @(Model.HallNumber ?? "-")</dd>
    <dt class="col-sm-2">Date / Time</dt>
    <dd class="col-sm-10">@Model.ShowDate.ToString("yyyy-MM-dd") @(string.IsNullOrWhiteSpace(Model.ShowTime) ? "-" : Model.ShowTime)</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ShowingId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
