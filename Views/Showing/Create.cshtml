@model Showing
@{
    ViewData["Title"] = "Create Showing";
    var halls = ViewBag.Halls as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var movies = ViewBag.Movies as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}
<h2>Create Showing (Showtime)</h2>
<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row mb-2">
        <div class="col-md-6">
            <label asp-for="HallId">Hall</label>
            <select asp-for="HallId" class="form-control" asp-items="@(new SelectList(halls, "HallId", "Display"))">
                <option value="">-- Select Hall --</option>
            </select>
            <span asp-validation-for="HallId" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="MovieId">Movie</label>
            <select asp-for="MovieId" class="form-control" asp-items="@(new SelectList(movies, "MovieId", "Display"))">
                <option value="">-- Select Movie --</option>
            </select>
            <span asp-validation-for="MovieId" class="text-danger"></span>
        </div>
    </div>
    <div class="row mb-2">
        <div class="col-md-6">
            <label asp-for="ShowDate"></label>
            <input asp-for="ShowDate" class="form-control" type="date" />
            <span asp-validation-for="ShowDate" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="ShowTime"></label>
            <select asp-for="ShowTime" class="form-control">
                <option value="">-- Select --</option>
                <option value="Morning">Morning</option>
                <option value="day">day</option>
                <option value="evening">evening</option>
            </select>
            <span asp-validation-for="ShowTime" class="text-danger"></span>
        </div>
    </div>
    <div class="row mb-2">
        <div class="col-md-6">
            <label asp-for="Status"></label>
            <select asp-for="Status" class="form-control">
                <option value="">-- Select --</option>
                <option value="Scheduled">Scheduled</option>
                <option value="Active">Active</option>
                <option value="Completed">Completed</option>
                <option value="Cancelled">Cancelled</option>
            </select>
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
