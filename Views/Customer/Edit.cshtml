@model Customer
@{
    ViewData["Title"] = "Edit Customer";
}
<div class="form-shell">
    <div class="page-header">
        <div class="page-header-title">Edit customer</div>
        <div class="page-header-subtitle">Update profile, contact details and dates for the selected user.</div>
    </div>

    <div class="form-card">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="CustomerId" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row mb-2">
                <div class="col-md-6">
                    <label asp-for="Username" class="form-label"></label>
                    <input asp-for="Username" class="form-control" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-2">
                <div class="col-md-6">
                    <label asp-for="CustomerEmail" class="form-label"></label>
                    <input asp-for="CustomerEmail" class="form-control" type="email" />
                    <span asp-validation-for="CustomerEmail" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" />
                </div>
            </div>

            <div class="row mb-2">
                <div class="col-12">
                    <label asp-for="CustomerAddress" class="form-label"></label>
                    <input asp-for="CustomerAddress" class="form-control" />
                </div>
            </div>

            <div class="row mb-2">
                <div class="col-md-6">
                    <label asp-for="CustomerCity" class="form-label"></label>
                    <input asp-for="CustomerCity" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="DateOfBirth" class="form-label"></label>
                    <input asp-for="DateOfBirth" class="form-control" type="date" />
                </div>
            </div>

            <div class="row mb-2">
                <div class="col-md-6">
                    <label asp-for="RegistrationDate" class="form-label"></label>
                    <input asp-for="RegistrationDate" class="form-control" type="date" />
                </div>
            </div>

            <div class="form-card-footer">
                <button type="submit" class="btn btn-primary">Save changes</button>
                <a asp-action="Index" class="btn btn-outline-primary">Back to list</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
