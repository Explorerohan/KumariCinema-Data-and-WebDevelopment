@model Customer
@{
    ViewData["Title"] = "Delete Customer";
}
<div class="form-shell">
    <div class="page-header">
        <div class="page-header-title">Delete customer</div>
        <div class="page-header-subtitle">This action is permanent. Review the summary below before confirming.</div>
    </div>

    <div class="danger-card">
        <div class="danger-card-header">
            <div class="danger-card-title">@Model.FullName</div>
        </div>
        <div class="danger-card-body">
            <dl class="row danger-meta-list mb-0">
                <dt class="col-sm-3">Customer ID</dt>
                <dd class="col-sm-9">@Model.CustomerId</dd>
                <dt class="col-sm-3">Username</dt>
                <dd class="col-sm-9">@Model.Username</dd>
                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.CustomerEmail</dd>
            </dl>
        </div>
        <form asp-action="Delete" method="post" class="mt-3 d-flex gap-2">
            <input type="hidden" asp-for="CustomerId" />
            <button type="submit" class="btn btn-outline-danger">Yes, delete customer</button>
            <a asp-action="Index" class="btn btn-outline-primary">Cancel</a>
        </form>
    </div>
</div>
