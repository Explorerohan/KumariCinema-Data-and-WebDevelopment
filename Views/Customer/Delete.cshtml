@model Customer
@{
    ViewData["Title"] = "Delete Customer";
}
<h2>Delete Customer</h2>
<p class="text-danger">Are you sure you want to delete this customer?</p>
<dl class="row">
    <dt class="col-sm-2">ID</dt>
    <dd class="col-sm-10">@Model.CustomerId</dd>
    <dt class="col-sm-2">Username</dt>
    <dd class="col-sm-10">@Model.Username</dd>
    <dt class="col-sm-2">Full Name</dt>
    <dd class="col-sm-10">@Model.FullName</dd>
    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.CustomerEmail</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="CustomerId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
