@model Movie
@{
    ViewData["Title"] = "Delete Movie";
}
<h2>Delete Movie</h2>
<p class="text-danger">Are you sure you want to delete this movie?</p>
<dl class="row">
    <dt class="col-sm-2">ID</dt>
    <dd class="col-sm-10">@Model.MovieId</dd>
    <dt class="col-sm-2">Title</dt>
    <dd class="col-sm-10">@Model.Title</dd>
    <dt class="col-sm-2">Duration</dt>
    <dd class="col-sm-10">@Model.Duration min</dd>
    <dt class="col-sm-2">Genre</dt>
    <dd class="col-sm-10">@(Model.Genre ?? "-")</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="MovieId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
