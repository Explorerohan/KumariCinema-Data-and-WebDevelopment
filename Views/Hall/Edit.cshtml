@model Hall
@{
    ViewData["Title"] = "Edit Hall";
    var theaters = ViewBag.Theaters as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}
<h2>Edit Hall</h2>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="HallId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row mb-2">
        <div class="col-md-6">
            <label asp-for="TheaterId">Theater</label>
            <select asp-for="TheaterId" class="form-control" asp-items="@(new SelectList(theaters, "TheaterId", "Display"))">
                <option value="">-- Select Theater --</option>
            </select>
            <span asp-validation-for="TheaterId" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="HallNumber"></label>
            <input asp-for="HallNumber" class="form-control" />
            <span asp-validation-for="HallNumber" class="text-danger"></span>
        </div>
    </div>
    <div class="row mb-2">
        <div class="col-md-6">
            <label asp-for="Capacity"></label>
            <input asp-for="Capacity" class="form-control" type="number" min="1" />
            <span asp-validation-for="Capacity" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="HallType"></label>
            <input asp-for="HallType" class="form-control" />
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
