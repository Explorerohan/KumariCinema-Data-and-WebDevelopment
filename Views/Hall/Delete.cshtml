@model Hall
@{
    ViewData["Title"] = "Delete Hall";
}
<h2>Delete Hall</h2>
<p class="text-danger">Are you sure you want to delete this hall?</p>
<dl class="row">
    <dt class="col-sm-2">Hall ID</dt>
    <dd class="col-sm-10">@Model.HallId</dd>
    <dt class="col-sm-2">Theater</dt>
    <dd class="col-sm-10">@(Model.TheaterName ?? "-")</dd>
    <dt class="col-sm-2">Hall Number</dt>
    <dd class="col-sm-10">@Model.HallNumber</dd>
    <dt class="col-sm-2">Capacity</dt>
    <dd class="col-sm-10">@Model.Capacity</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="HallId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
